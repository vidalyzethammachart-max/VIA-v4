VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
N8N_WEBHOOK_URL=https://vidalyze.app.n8n.cloud/webhook/google-form-hook
# Upload backend origin. The frontend derives /api/r2-presign-upload from this URL.
VITE_UPLOAD_VIDEO_API_URL=https://via-v3.onrender.com/api/upload-video
# Upload mode: "legacy" sends multipart video through the backend relay, "r2" uploads directly to R2.
VITE_VIDEO_UPLOAD_MODE=r2
CORS_ORIGIN=http://localhost:5173,https://via3-app.vercel.app
R2_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID
R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY
R2_BUCKET_NAME=YOUR_R2_BUCKET_NAME
R2_UPLOAD_URL_TTL_SECONDS=900
R2_DOWNLOAD_URL_TTL_SECONDS=86400
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash
# Server-only values for POST /api/n8n-analysis-result. Do not expose either value with VITE_.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
N8N_CALLBACK_SECRET=GENERATE_A_LONG_RANDOM_SECRET
